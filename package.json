{
  "name": "fio-mcp",
  "version": "1.0.0",
  "description": "A Model Context Protocol server for FIO / Prosperous Universe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/themanwithanrx7/fio-mcp.git"
  },
  "homepage": "https://github.com/themanwithanrx7/fio-mcp#readme",
  "bugs": "https://github.com/themanwithanrx7/fio-mcp/issues",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "exports": "./dist/index.js",
  "bin": {
    "fio-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "oxlint src/",
    "fmt": "oxfmt --write src/",
    "fmt:check": "oxfmt --check src/",
    "check": "npm run fmt:check && npm run lint && npm run build",
    "prepublishOnly": "npm run check"
  },
  "keywords": [
    "model-context-protocol",
    "mcp",
    "fio",
    "prosperous-universe",
    "mcp-server"
  ],
  "author": "themanwithanrx7",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^2.1.9"
  }
}
